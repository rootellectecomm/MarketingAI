ENVIRONMENT=local
DEBUG=true
DATABASE_URL=postgresql+asyncpg://rootellect:rootellect@localhost:5432/rootellect
REDIS_URL=redis://localhost:6379/0
CHROMA_HOST=localhost
CHROMA_PORT=8001
JWT_SECRET_KEY=change-this-jwt-secret
ENCRYPTION_SECRET=change-this-encryption-secret
ADMIN_EMAIL=admin@rootellect.com
ADMIN_PASSWORD=ChangeMe123!
RESET_ADMIN_SECRET=rootellect-reset-secret
META_VERIFY_TOKEN=rootellect-webhook-token
META_APP_ID=
META_APP_SECRET=replace-meta-app-secret
META_OAUTH_REDIRECT_URI=https://your-backend-domain.com/api/v1/meta/callback
BACKEND_CORS_ORIGINS=http://localhost:3000,https://marketing-ai-gamma-virid.vercel.app
META_CONNECT_SUCCESS_URL=https://marketing-ai-gamma-virid.vercel.app/settings
# Optional: required for Meta's newer Facebook Login for Business flow.
# Create this in Meta App Dashboard > Facebook Login for Business > Configurations.
META_LOGIN_CONFIG_ID=
META_OAUTH_SCOPES=pages_show_list,pages_read_engagement,pages_manage_metadata,pages_manage_engagement,instagram_basic,instagram_manage_comments,instagram_manage_messages
PROVIDER_MODE=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Phase 3 — Shopify cart recovery (optional)
SHOPIFY_WEBHOOK_SECRET=
SHOPIFY_STORE_DOMAIN=
